    "print(\"TASK 4\"+\"\\n\"+\"=\"*100)\n",
    "class Portfolio:\n",
    "    def __init__(self, owner):\n",
    "        self.owner = owner\n",
    "        self.holdings = {}  # ticker -> {shares, price_per_share}\n",
    "    \"\"\"\n",
    "    PART A\n",
    "    \"\"\"\n",
    "    def add_asset(self, ticker, shares, price_per_share):\n",
    "        self.holdings[ticker] = {'shares': shares, 'price': price_per_share}\n",
    "    \"\"\"\n",
    "    PART B\n",
    "    \"\"\"\n",
    "    def total_value(self):\n",
    "        return sum(i['shares'] * i['price'] for i in self.holdings.values())\n",
    "    \"\"\"\n",
    "    PART C\n",
    "    \"\"\"\n",
    "    def most_valuable(self):\n",
    "        return max(self.holdings, key=lambda i: self.holdings[i]['shares'] * self.holdings[i]['price'])\n",
    "    \"\"\"\n",
    "    PART D: the owner's name, the number of assets, and the total value.\n",
    "    \"\"\"\n",
    "    def __str__(self):\n",
    "         return f'{self.owner} has {len(self.holdings)} assets\\n- The total value of asset: {self.total_value()}. \\n- The most valuable share in this Portfolio is {self.most_valuable()}'\n",
    "\n",
    "\"\"\"\n",
    "Create an instance, add at least three assets, and demonstrate all methods with printed output.\n",
